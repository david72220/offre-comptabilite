---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}

const { title: rawTitle, description = "Accompagnement clé en main de la comptabilité et de la gestion commerciale des TPE.", noindex = false } = Astro.props;

const title = rawTitle.length > 60 ? rawTitle.slice(0, 59) + '…' : rawTitle;
const siteUrl = 'https://offre-comptabilite.vercel.app';

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/stack-a/', label: 'Stack A' },
  { href: '/stack-b/', label: 'Stack B' },
  { href: '/stack-c/', label: 'Stack C' },
  { href: '/stack-d/', label: 'Stack D' },
  { href: '/livrables/', label: 'Livrables' },
];
---

<!DOCTYPE html>
<html lang="fr-FR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Alliance Digitale</title>
  <meta name="description" content={description} />
  {!noindex && <meta name="robots" content="index, follow" />}
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={Astro.url.href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_FR" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="theme-color" content="#070d18" />
</head>
<body class="min-h-screen flex flex-col bg-alliance-dark text-white">
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-alliance-orange text-white px-4 py-2 rounded">
    Aller au contenu principal
  </a>

  <!-- HEADER -->
  <header class="bg-alliance-dark-2 border-b border-white/10 sticky top-0 z-50 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-3 group" aria-label="Alliance Digitale — retour à l'accueil">
          <span class="font-script text-3xl text-alliance-orange group-hover:text-white transition-colors">Alliance Digitale</span>
        </a>
        <nav class="hidden md:flex items-center gap-6" aria-label="Navigation principale">
          {navLinks.map(link => (
            <a href={link.href} class="text-white/70 hover:text-white transition-colors text-sm font-medium">{link.label}</a>
          ))}
          <a href="/#audit" class="btn-primary text-xs py-2 px-4">Audit gratuit</a>
        </nav>
        <button id="menu-toggle" class="md:hidden text-white p-2" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden bg-alliance-dark-2 border-t border-white/10">
      <nav class="flex flex-col px-4 py-4 gap-3" aria-label="Navigation mobile">
        {navLinks.map(link => (
          <a href={link.href} class="py-2 text-white/70 hover:text-white transition-colors">{link.label}</a>
        ))}
        <a href="/#audit" class="btn-primary text-center mt-2">Audit gratuit</a>
      </nav>
    </div>
  </header>

  <main id="main" class="flex-grow">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="bg-alliance-dark-2 border-t border-white/10 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <span class="font-script text-3xl text-alliance-orange">Alliance Digitale</span>
          <p class="mt-4 text-sm text-white/60 max-w-xs">
            Accompagnement clé en main de la comptabilité et de la gestion commerciale des TPE. Installation, formation et autonomie.
          </p>
        </div>
        <div>
          <h3 class="font-display font-semibold mb-4 text-white">Liens utiles</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/mentions-legales/" class="text-white/60 hover:text-alliance-blue transition-colors">Mentions légales</a></li>
            <li><a href="/politique-de-confidentialite/" class="text-white/60 hover:text-alliance-blue transition-colors">Politique de confidentialité</a></li>
            <li><a href="/livrables/" class="text-white/60 hover:text-alliance-blue transition-colors">Galerie des livrables</a></li>
            <li><a href="/#audit" class="text-white/60 hover:text-alliance-blue transition-colors">Audit en ligne</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-display font-semibold mb-4 text-white">Contact</h3>
          <p class="text-sm text-white/60">
            David Pierre Olivier<br />
            <a href="mailto:contact@alliance-digitale.fr" class="text-alliance-blue hover:text-alliance-blue-light transition-colors">contact@alliance-digitale.fr</a><br />
            Ecommoy, Sarthe
          </p>
        </div>
      </div>
      <div class="border-t border-white/10 mt-10 pt-6 text-sm text-white/40 text-center">
        © {new Date().getFullYear()} Alliance Digitale. Tous droits réservés.
      </div>
    </div>
  </footer>

  <script is:inline>
    // Mobile menu toggle
    (function () {
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      if (toggle && menu) {
        toggle.addEventListener('click', function () {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!expanded));
          menu.classList.toggle('hidden');
        });
      }
    })();

    // Reveal animations — IntersectionObserver
    // CSS sets [data-reveal] { opacity: 0 } so we MUST animate them in
    (function () {
      var els = document.querySelectorAll('[data-reveal]');
      if (!els.length) return;

      // If user prefers reduced motion, show everything immediately
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach(function (el) { el.style.opacity = '1'; el.style.transform = 'none'; });
        return;
      }

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            var el = entry.target;
            var delay = parseFloat(el.dataset.revealDelay) || 0;
            setTimeout(function () {
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            }, delay * 1000);
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.1 });

      els.forEach(function (el) {
        el.style.transform = 'translateY(24px)';
        el.style.transition = 'opacity 0.6s ease-out, transform 0.6s ease-out';
        observer.observe(el);
      });
    })();
  </script>
</body>
</html>