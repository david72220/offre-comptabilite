---
import Layout from '../layouts/Layout.astro';

const title = 'Stack A — Essentiel Solo';
const description = 'Accompagnement Qonto + Indy pour dirigeant solo : installation, paramétrage et formation 1h. Devis, factures, TVA et trésorerie maîtrisés.';

const program = [
  { time: '0-5 min', duration: "5'", title: 'Tour de table et positionnement', desc: 'Rappel des objectifs, ajustement du programme selon votre contexte.' },
  { time: '5-15 min', duration: "10'", title: 'Configuration Qonto', desc: 'Profil entreprise, mentions légales 2026, logo, numérotation des factures.' },
  { time: '15-30 min', duration: "15'", title: 'Cycle devis → facture', desc: 'Création d’un devis-type, envoi client, conversion sans ressaisie, envoi de facture.' },
  { time: '30-40 min', duration: "10'", title: 'Facture électronique fournisseur', desc: 'Configuration annuaire PA, réception, validation et archivage.' },
  { time: '40-50 min', duration: "10'", title: 'Indy : compta et TVA', desc: 'Synchronisation bancaire, catégorisation automatique, préparation TVA.' },
  { time: '50-60 min', duration: "10'", title: 'Récap et conformité', desc: 'Points de vigilance facturation électronique 09/2026 et 09/2027, remise du livret.' },
];

const objectives = [
  'Créer un devis conforme aux mentions légales 2026 sur Qonto en moins de 3 minutes',
  'Transformer un devis accepté en facture sans ressaisie',
  'Recevoir une facture électronique de fournisseur via l’annuaire PA',
  'Suivre ses encaissements et sa trésorerie en temps réel',
  'Exporter son FEC et sa déclaration TVA depuis Indy',
  'Identifier les obligations réglementaires facturation électronique 2026-2027 et son propre calendrier',
];

const deliverables = [
  'Livret utilisateur personnalisé PDF (6-8 pages)',
  'Accès Notion "Fiches réflexe Qonto + Indy"',
  '3 vidéos courtes (2-3 min) : créer un devis, recevoir une facture électronique, déclarer sa TVA',
  'Certificat d’assiduité',
];

const skills = [
  'Créer un devis PDF conforme mentions légales 2026 en 3 minutes',
  'Personnaliser un modèle de facture (logo, couleurs, conditions de règlement)',
  'Numéroter automatiquement vos factures (séquence continue)',
  'Recevoir une facture électronique via l’annuaire des Plateformes Agréées',
  'Distinguer une facture électronique conforme d’un simple PDF',
  'Suivre les statuts de vos factures émises',
  'Envoyer une relance simple à un client en retard',
  'Consulter votre trésorerie disponible en temps réel',
  'Catégoriser automatiquement une dépense bancaire dans Indy',
  'Attacher un justificatif photo à une dépense via mobile',
  'Générer votre déclaration TVA depuis Indy',
  'Exporter votre FEC pour l’expert-comptable ou un contrôle',
  'Émettre une note de frais mobile depuis votre smartphone',
];
---

<Layout title={title} description={description}>
  <section class="relative overflow-hidden bg-alliance-dark-2 pt-24 pb-16 px-4 sm:px-6 lg:px-8">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-alliance-blue/10 via-transparent to-transparent"></div>
    <div class="relative max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-alliance-blue font-semibold tracking-widest uppercase text-sm mb-3" data-hero-anim="badge">Stack A</p>
          <h1 class="font-serif text-5xl md:text-6xl mb-6 text-white" data-hero-anim="title">Essentiel Solo</h1>
          <p class="text-lg md:text-xl text-white/80 mb-6" data-hero-anim="lead">
            Prendre en main sa gestion commerciale avec Qonto et Indy. Pour le dirigeant solo qui veut émettre des devis et factures conformes, suivre sa trésorerie et préparer sa TVA sans perdre de temps.
          </p>
          <div class="flex flex-wrap gap-3 mb-8" data-hero-anim="tools">
            <span class="px-4 py-2 rounded-full bg-white/10 text-white text-sm font-medium">Qonto</span>
            <span class="px-4 py-2 rounded-full bg-white/10 text-white text-sm font-medium">Indy</span>
          </div>
          <div class="flex flex-col sm:flex-row gap-4" data-hero-anim="cta">
            <a href="/#audit" class="btn-primary">Demander un devis</a>
            <a href="/livrables/" class="btn-secondary">Voir les livrables</a>
          </div>
        </div>
        <div class="relief-panel p-8" data-reveal>
          <p class="text-sm text-white/60 uppercase tracking-wide mb-2">Investissement</p>
          <p class="text-5xl font-bold gradient-text mb-2">690 € HT</p>
          <p class="text-white/70 mb-6">Formation individuelle 1 heure comprise</p>
          <hr class="border-white/10 mb-6" />
          <ul class="space-y-3">
            <li class="flex items-center gap-2 text-white/80">
              <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span>Installation et paramétrage Qonto + Indy</span>
            </li>
            <li class="flex items-center gap-2 text-white/80">
              <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span>Formation 1h en visio partagée</span>
            </li>
            <li class="flex items-center gap-2 text-white/80">
              <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span>Livret personnalisé et fiches réflexe</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-alliance-dark" data-reveal>
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="relief-panel p-8">
          <h2 class="font-serif text-2xl md:text-3xl font-bold text-white mb-4">Public visé</h2>
          <p class="text-white/80 text-lg">
            Dirigeant solo de très petite entreprise (freelance, consultant, coach, artisan solo, profession libérale) réalisant moins de 30 factures par mois, sans expert-comptable ou avec un expert-comptable acceptant le format numérique standard (FEC).
          </p>
        </div>
        <div class="relief-panel p-8">
          <h2 class="font-serif text-2xl md:text-3xl font-bold text-white mb-4">Prérequis</h2>
          <ul class="space-y-2 text-white/80">
            <li>Savoir naviguer sur un site web et manipuler une adresse email</li>
            <li>Comprendre les notions de base de TVA (assujetti ou non, taux normal)</li>
            <li>Connaître son SIRET, son code APE et son régime fiscal (BIC/BNC, réel simplifié ou micro)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-alliance-dark-2" data-reveal>
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-10 text-center" data-reveal>Objectifs pédagogiques</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {objectives.map((objective, i) => (
          <div class="relief-panel p-6" data-reveal data-reveal-delay={String(i * 0.08)}>
            <div class="flex items-start gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-alliance-blue text-white flex items-center justify-center font-bold">{i + 1}</span>
              <p class="text-white/90">{objective}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-alliance-dark course-content" data-reveal>
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-10 text-center" data-reveal>Programme détaillé (60 minutes)</h2>
      <div class="space-y-6">
        {program.map((item, i) => (
          <div class="relief-panel p-6" data-reveal data-reveal-delay={String(i * 0.06)}>
            <div class="md:grid md:grid-cols-12 md:gap-6 items-start">
              <div class="md:col-span-3 mb-2 md:mb-0">
                <p class="font-semibold text-white">{item.time}</p>
                <p class="text-sm text-white/60">{item.duration}</p>
              </div>
              <div class="md:col-span-9">
                <h3 class="text-xl font-bold text-white mb-1">{item.title}</h3>
                <p class="text-white/70">{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-alliance-dark-2" data-reveal>
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-10 text-center" data-reveal>Ce que vous saurez faire</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {skills.map((skill, i) => (
          <div class="flex items-start gap-3 relief-panel p-4" data-reveal data-reveal-delay={String(i * 0.04)}>
            <svg class="w-5 h-5 text-alliance-orange shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-white/90">{skill}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-alliance-dark" data-reveal>
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div data-reveal>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-6">Livrables remis au stagiaire</h2>
          <ul class="space-y-4">
            {deliverables.map((item) => (
              <li class="flex items-start gap-3 text-white/90">
                <svg class="w-5 h-5 text-alliance-blue shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="relief-panel p-8" data-reveal>
          <h3 class="text-2xl font-bold text-white mb-4">Évaluation finale</h3>
          <p class="text-white/70 mb-4">
            En 15 minutes, le stagiaire réalise en autonomie : création d’un devis, conversion en facture, ajout d’une dépense avec justificatif, consultation du tableau de bord trésorerie.
          </p>
          <p class="font-semibold text-white">Réussite = 4 tâches sur 4 accomplies sans intervention du formateur.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-alliance-dark-2" data-reveal>
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-white mb-6">Vous êtes un dirigeant solo ?</h2>
      <p class="text-white/70 text-lg mb-8">Démarrez votre accompagnement Stack A dès maintenant. Audit gratuit et devis sous 48 heures.</p>
      <a href="/#audit" class="btn-primary text-base px-8 py-4">Faire l’audit</a>
    </div>
  </section>
</Layout>
