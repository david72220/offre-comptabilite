---
import Layout from '../layouts/Layout.astro';

const title = 'Stack B — Confort TPE';
const description = 'Accompagnement Qonto + Pennylane + Notion pour TPE de 2 à 8 personnes. Installation, formation 1 journée, relances, lettrage et prévisionnel de trésorerie.';

const morning = [
  { time: '09h00-09h30', duration: "30'", title: 'Accueil et positionnement', desc: 'Tour de table, réajustement du programme selon les enjeux réels du jour, exposé des objectifs mesurables.' },
  { time: '09h30-10h15', duration: "45'", title: 'Fondamentaux réglementaires', desc: 'Facturation électronique 2026-2027, mentions obligatoires, impacts sur votre entreprise.' },
  { time: '10h15-11h00', duration: "45'", title: 'Structuration du catalogue', desc: 'Catégories, tarifs, taux de TVA, unités de mesure, remises paramétrées.' },
  { time: '11h00-11h15', duration: "15'", title: 'Pause', desc: '' },
  { time: '11h15-12h00', duration: "45'", title: 'Modèles de documents', desc: 'Devis et facture personnalisés, numérotation, conditions générales de vente.' },
  { time: '12h00-12h30', duration: "30'", title: 'Base clients', desc: 'Structuration B2B/B2C, données e-invoicing, import Excel/CSV.' },
];

const afternoon = [
  { time: '13h30-14h15', duration: "45'", title: 'Cycle de vente complet', desc: 'Devis, signature électronique, facturation d’acompte, factures récurrentes.' },
  { time: '14h15-15h00', duration: "45'", title: 'Relances automatiques', desc: 'Scénarios 7/15/30 jours, personnalisation par typologie client, exceptions.' },
  { time: '15h00-15h15', duration: "15'", title: 'Pause', desc: '' },
  { time: '15h15-16h00', duration: "45'", title: 'Connexion bancaire et lettrage', desc: 'Synchro Qonto ↔ Pennylane, catégorisation, lettrage semi-automatique, cas complexes.' },
  { time: '16h00-16h45', duration: "45'", title: 'Pilotage', desc: 'Tableau de bord trésorerie, DSO, forecast 30/60 jours, indicateurs par client et par produit.' },
  { time: '16h45-17h00', duration: "15'", title: 'Récapitulatif et évaluation', desc: 'Cas pratique final en autonomie, réponses aux dernières questions, attestation.' },
];

const objectives = [
  'Structurer son catalogue produits/prestations avec les bons taux de TVA',
  'Créer un devis complexe (multi-lignes, remises, acomptes) et le suivre jusqu’à signature',
  'Émettre une facture électronique conforme et la transmettre via Pennylane',
  'Paramétrer des relances automatiques différenciées par typologie de client',
  'Rapprocher ses paiements clients avec ses factures (lettrage) en autonomie',
  'Piloter sa trésorerie prévisionnelle et anticiper ses besoins de financement',
  'Collaborer en temps réel avec son expert-comptable via Pennylane',
  'Segmenter ses clients dans Notion et suivre son pipeline commercial',
];

const deliverables = [
  'Livret utilisateur personnalisé (12-14 pages) — captures de votre environnement',
  'Fichier catalogue produits/prestations structuré (Excel/CSV)',
  'Template Notion "Suivi commercial TPE" configuré à vos couleurs',
  '7 vidéos tutorielles sur les workflows clés',
  'Accès Notion "Fiches réflexe Pennylane"',
  '30 jours de hotline mail post-formation',
];

const qontoSkills = [
  'Émettre virements SEPA instantanés et programmés',
  'Créer et gérer des cartes physiques et virtuelles avec plafonds différenciés',
  'Suivre les dépenses par catégorie et par utilisateur',
  'Automatiser la collecte des justificatifs',
  'Configurer les droits d’accès pour un salarié ou un associé',
  'Recevoir les factures électroniques via la Plateforme Agréée Qonto',
  'Extraire un IBAN virtuel dédié à un client',
  'Encaisser via lien de paiement',
];

const pennylaneSkills = [
  'Créer un devis multi-lignes avec remises, acomptes, conditions de règlement',
  'Générer un devis en moins de 90 secondes à partir du catalogue',
  'Faire signer un devis électroniquement',
  'Convertir un devis accepté en facture en 1 clic sans ressaisie',
  'Émettre une facture d’acompte, de solde, un avoir',
  'Créer une facture récurrente',
  'Envoyer la facture par email avec suivi',
  'Émettre une facture électronique conforme (Factur-X / UBL)',
  'Paramétrer un scénario de relance à 3 étapes',
  'Lettrer automatiquement les paiements reçus',
  'Traiter les cas de lettrage complexe',
  'Générer un prévisionnel de trésorerie à 30/60/90 jours',
  'Suivre le DSO global et par client',
  'Extraire un FEC ou un journal comptable',
  'Partager le portail avec l’expert-comptable',
];

const notionSkills = [
  'Utiliser le template "Suivi commercial TPE Alliance Digitale"',
  'Structurer une base clients enrichie',
  'Suivre un pipeline commercial simple',
  'Gérer une base documentaire partagée',
  'Créer un tableau de bord d’activité mensuel',
  'Partager un espace de travail avec un associé ou un assistant',
];
---

<Layout title={title} description={description}>
  <section class="relative overflow-hidden bg-alliance-dark-2 pt-24 pb-16 px-4 sm:px-6 lg:px-8" data-reveal>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-alliance-blue/10 via-transparent to-transparent"></div>
    <div class="relative max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-alliance-blue font-semibold tracking-widest uppercase text-sm mb-3" data-hero-anim="badge">Stack B</p>
          <h1 class="font-serif text-5xl md:text-6xl mb-6 text-white" data-hero-anim="title">Confort TPE</h1>
          <p class="text-lg md:text-xl text-white/80 mb-6" data-hero-anim="lead">
            Gérer son cycle commercial de bout en bout avec Qonto, Pennylane et Notion. Pour la TPE de 2 à 8 personnes qui veut passer à une gestion commerciale professionnelle sans dépendre d’un prestataire.
          </p>
          <div class="flex flex-wrap gap-3 mb-8" data-hero-anim="tools">
            <span class="px-4 py-2 rounded-full bg-white/10 text-white text-sm font-medium">Qonto</span>
            <span class="px-4 py-2 rounded-full bg-white/10 text-white text-sm font-medium">Pennylane</span>
            <span class="px-4 py-2 rounded-full bg-white/10 text-white text-sm font-medium">Notion</span>
          </div>
          <div class="flex flex-col sm:flex-row gap-4" data-hero-anim="cta">
            <a href="/#audit" class="btn-primary">Demander un devis</a>
            <a href="/livrables/" class="btn-secondary">Voir les livrables</a>
          </div>
        </div>
        <div class="relief-panel p-8" data-reveal>
          <p class="text-sm text-white/60 uppercase tracking-wide mb-2">Investissement</p>
          <p class="text-5xl font-bold gradient-text mb-2">690 € HT + 600 € HT</p>
          <p class="text-white/70 mb-6">Accompagnement + formation 1 journée / 7h</p>
          <hr class="border-white/10 mb-6" />
          <ul class="space-y-3">
            <li class="flex items-center gap-2 text-white/80">
              <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span>Installation Qonto + Pennylane + Notion</span>
            </li>
            <li class="flex items-center gap-2 text-white/80">
              <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span>Formation 1 journée (présentiel ou visio)</span>
            </li>
            <li class="flex items-center gap-2 text-white/80">
              <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span>Catalogue, relances, lettrage et prévisionnel</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-alliance-dark" data-reveal>
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="relief-panel p-8">
          <h2 class="font-serif text-2xl md:text-3xl font-bold text-white mb-4">Public visé</h2>
          <p class="text-white/80 text-lg">
            Dirigeants et administratifs de TPE de 2 à 8 personnes, réalisant entre 30 et 150 factures par mois, travaillant ou souhaitant travailler avec un expert-comptable équipé Pennylane ou compatible FEC standard.
          </p>
        </div>
        <div class="relief-panel p-8">
          <h2 class="font-serif text-2xl md:text-3xl font-bold text-white mb-4">Prérequis</h2>
          <ul class="space-y-2 text-white/80">
            <li>Notions de base sur la facturation (mentions légales, TVA, échéance)</li>
            <li>Savoir utiliser un ordinateur et naviguer sur le web</li>
            <li>Avoir un compte bancaire professionnel actif ou en cours d’ouverture</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-alliance-dark-2" data-reveal>
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-10 text-center" data-reveal>Objectifs pédagogiques</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {objectives.map((objective, i) => (
          <div class="relief-panel p-6" data-reveal data-reveal-delay={String(i * 0.08)}>
            <div class="flex items-start gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-alliance-blue text-white flex items-center justify-center font-bold">{i + 1}</span>
              <p class="text-white/90">{objective}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-alliance-dark course-content" data-reveal>
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-10 text-center" data-reveal>Programme détaillé (1 journée / 7 heures)</h2>

      <h3 class="font-display text-xl font-bold text-alliance-blue mb-6" data-reveal>Matinée — Configuration et fondamentaux</h3>
      <div class="space-y-6 mb-12">
        {morning.map((item, i) => (
          <div class="relief-panel p-6" data-reveal data-reveal-delay={String(i * 0.06)}>
            <div class="md:grid md:grid-cols-12 md:gap-6 items-start">
              <div class="md:col-span-3 mb-2 md:mb-0">
                <p class="font-semibold text-white">{item.time}</p>
                <p class="text-sm text-white/60">{item.duration}</p>
              </div>
              <div class="md:col-span-9">
                <h4 class="text-xl font-bold text-white mb-1">{item.title}</h4>
                <p class="text-white/70">{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <h3 class="font-display text-xl font-bold text-alliance-blue mb-6" data-reveal>Après-midi — Vente, automation et pilotage</h3>
      <div class="space-y-6">
        {afternoon.map((item, i) => (
          <div class="relief-panel p-6" data-reveal data-reveal-delay={String(i * 0.06)}>
            <div class="md:grid md:grid-cols-12 md:gap-6 items-start">
              <div class="md:col-span-3 mb-2 md:mb-0">
                <p class="font-semibold text-white">{item.time}</p>
                <p class="text-sm text-white/60">{item.duration}</p>
              </div>
              <div class="md:col-span-9">
                <h4 class="text-xl font-bold text-white mb-1">{item.title}</h4>
                <p class="text-white/70">{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-alliance-dark-2" data-reveal>
    <div class="max-w-6xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-10 text-center" data-reveal>Ce que vous saurez faire</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div data-reveal>
          <h3 class="font-display text-xl font-bold text-alliance-blue mb-4">Sur Qonto</h3>
          <ul class="space-y-2">
            {qontoSkills.map((skill) => (
              <li class="flex items-start gap-2 text-white/90">
                <svg class="w-4 h-4 text-alliance-orange shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span>{skill}</span>
              </li>
            ))}
          </ul>
        </div>
        <div data-reveal>
          <h3 class="font-display text-xl font-bold text-alliance-blue mb-4">Sur Pennylane</h3>
          <ul class="space-y-2">
            {pennylaneSkills.map((skill) => (
              <li class="flex items-start gap-2 text-white/90">
                <svg class="w-4 h-4 text-alliance-orange shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span>{skill}</span>
              </li>
            ))}
          </ul>
        </div>
        <div data-reveal>
          <h3 class="font-display text-xl font-bold text-alliance-blue mb-4">Sur Notion</h3>
          <ul class="space-y-2">
            {notionSkills.map((skill) => (
              <li class="flex items-start gap-2 text-white/90">
                <svg class="w-4 h-4 text-alliance-orange shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span>{skill}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-alliance-dark" data-reveal>
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div data-reveal>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-6">Livrables remis au stagiaire</h2>
          <ul class="space-y-4">
            {deliverables.map((item) => (
              <li class="flex items-start gap-3 text-white/90">
                <svg class="w-5 h-5 text-alliance-blue shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="relief-panel p-8" data-reveal>
          <h3 class="font-serif text-2xl font-bold text-white mb-4">Évaluation finale</h3>
          <p class="text-white/70 mb-4">
            Cas pratique de 45 minutes : à partir d’une commande fictive, créer le devis, obtenir sa signature simulée, le transformer en facture avec acompte, paramétrer les relances, saisir un règlement partiel et lire l’impact sur la trésorerie prévisionnelle.
          </p>
          <p class="font-semibold text-white">Réussite = 6 tâches sur 7 sans erreur bloquante.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-alliance-dark-2" data-reveal>
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-white mb-6">Votre TPE passe au niveau supérieur ?</h2>
      <p class="text-white/70 text-lg mb-8">Demandez un audit gratuit. Nous vous orientons vers le Stack B si votre volume et vos besoins de pilotage le justifient.</p>
      <a href="/#audit" class="btn-primary text-base px-8 py-4">Faire l’audit</a>
    </div>
  </section>
</Layout>
