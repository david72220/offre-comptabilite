---
import Layout from '../layouts/Layout.astro';

const title = 'Livrables de l’accompagnement';
const description = 'Découvrez tous les livrables fournis avec chaque pack d’accompagnement Alliance Digitale : livret personnalisé, fiches réflexe, vidéos tutorielles, hotline et attestations.';

const deliverables = [
  {
    stack: 'Tous les stacks',
    name: 'Livret utilisateur personnalisé',
    description: 'PDF de 6 à 18 pages avec des captures d’écran de votre propre environnement, vos modèles, votre charte couleurs, et les étapes clés de vos workflows.',
    icon: '📘',
  },
  {
    stack: 'Tous les stacks',
    name: 'Fiches réflexe Notion',
    description: 'Accès à un espace Notion dédié avec des fiches réflexe par workflow, des checklists et une base documentaire évolutive.',
    icon: '📝',
  },
  {
    stack: 'Tous les stacks',
    name: 'Vidéos tutorielles',
    description: 'Courtes vidéos de 2 à 5 minutes enregistrées sur votre environnement : créer un devis, relancer un client, déclarer la TVA, etc.',
    icon: '🎬',
  },
  {
    stack: 'Tous les stacks',
    name: 'Attestation de formation',
    description: 'Certificat d’assiduité et évaluation des acquis délivrés à l’issue de la formation.',
    icon: '🎓',
  },
  {
    stack: 'Stack B, C, D',
    name: 'Catalogue produits structuré',
    description: 'Fichier Excel/CSV prêt à l’import avec les familles, taux de TVA, remises et unités de mesure.',
    icon: '📊',
  },
  {
    stack: 'Stack B',
    name: 'Template Notion Suivi commercial TPE',
    description: 'Espace de travail Notion configuré avec base clients, pipeline commercial, base documentaire et tableau de bord mensuel.',
    icon: '🗂️',
  },
  {
    stack: 'Stack C',
    name: 'Configuration Axonaut opérationnelle',
    description: 'Pipeline, workflows, modèles de documents, relances et tableaux de bord configurés dans votre compte Axonaut.',
    icon: '⚙️',
  },
  {
    stack: 'Stack D',
    name: 'Bibliothèque d’ouvrages BTP',
    description: 'Bibliothèque d’ouvrages type importable et modèles de devis/factures BTP conformes.',
    icon: '🏗️',
  },
  {
    stack: 'Tous les stacks',
    name: 'Hotline post-formation',
    description: 'Support email pendant 30 à 60 jours selon le pack, pour sécuriser vos premiers pas en autonomie.',
    icon: '🛟',
  },
];

const documents = [
  { label: 'Convention de formation', desc: 'Préalable obligatoire signé numériquement avant le démarrage.' },
  { label: 'Programme pédagogique', desc: 'Envoyé 72h avant la formation avec les objectifs et le déroulé.' },
  { label: 'Feuille d’émargement', desc: 'Signatures dématérialisées du stagiaire et du formateur.' },
  { label: 'Attestation de formation', desc: 'Délivrée sous 48h après la session.' },
  { label: 'Livret personnalisé', desc: 'Remis à chaud en fin de formation et mis à jour si besoin.' },
  { label: 'Compte-rendu d’évaluation', desc: 'Score final, points forts et axes d’amélioration.' },
];
---

<Layout title={title} description={description}>
  <section class="relative overflow-hidden bg-alliance-dark-2 pt-24 pb-16 px-4 sm:px-6 lg:px-8">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-alliance-blue/10 via-transparent to-transparent"></div>
    <div class="relative max-w-5xl mx-auto text-center">
      <p class="text-alliance-blue font-semibold tracking-wide uppercase text-sm mb-3" data-hero-anim="badge">Accompagnement clair</p>
      <h1 class="font-script text-5xl md:text-6xl mb-6 text-white" data-hero-anim="title">Nos livrables</h1>
      <p class="text-lg md:text-xl text-white/70 max-w-3xl mx-auto" data-hero-anim="lead">
        Chaque pack d’accompagnement livre une documentation opérationnelle personnalisée, des vidéos et un suivi post-formation pour garantir votre autonomie.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {deliverables.map((item, i) => (
          <div class="relief-panel p-6" data-reveal data-reveal-delay={String(i * 0.06)}>
            <div class="flex items-start justify-between mb-4">
              <span class="text-3xl">{item.icon}</span>
              <span class="text-xs font-semibold uppercase tracking-wider px-2 py-1 rounded bg-white/10 text-white/70">{item.stack}</span>
            </div>
            <h3 class="font-display text-xl font-bold text-white mb-3">{item.name}</h3>
            <p class="text-white/70 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-alliance-dark-2">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div data-reveal>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-6">Documents administratifs</h2>
          <p class="text-white/70 text-lg leading-relaxed mb-6">
            La formation est encadrée par les règles Qualiopi / OPCO. Tous les documents réglementaires sont produits et conservés pour votre compte.
          </p>
          <a href="/#audit" class="btn-primary">Démarrer un accompagnement</a>
        </div>
        <div class="space-y-4">
          {documents.map((doc, i) => (
            <div class="relief-panel p-5" data-reveal data-reveal-delay={String(i * 0.06)}>
              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 w-10 h-10 rounded-full bg-alliance-orange text-white flex items-center justify-center font-bold">{i + 1}</span>
                <div>
                  <h3 class="font-semibold text-white">{doc.label}</h3>
                  <p class="text-white/60 text-sm">{doc.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center" data-reveal>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-white mb-6">Besoin d’un devis personnalisé ?</h2>
      <p class="text-white/70 text-lg mb-8">Remplissez l’audit en ligne. Nous vous proposons le pack et les livrables adaptés à votre activité.</p>
      <a href="/#audit" class="btn-primary text-base px-8 py-4">Faire l’audit gratuit</a>
    </div>
  </section>
</Layout>
