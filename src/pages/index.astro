---
import Layout from '../layouts/Layout.astro';
import MatriceAudit from '../components/MatriceAudit.tsx';

const title = 'Accompagnement comptabilité TPE, clé en main';
const description = 'Alliance Digitale accompagne les TPE dans la mise en place de leur comptabilité et gestion commerciale : installation, formation et autonomie opérationnelle.';

const stacks = [
  {
    id: 'A',
    name: 'Stack A — Essentiel Solo',
    slug: '/stack-a/',
    price: '690 € HT',
    detail: 'formation 1h comprise',
    tools: ['Qonto', 'Indy'],
    benefits: [
      'Devis et factures conformes 2026 en 3 minutes',
      'Trésorerie et déclaration TVA maîtrisées',
      'Accompagnement individuel par visio',
    ],
    color: 'blue',
  },
  {
    id: 'B',
    name: 'Stack B — Confort TPE',
    slug: '/stack-b/',
    price: '690 € HT + 600 € HT',
    detail: 'accompagnement + formation 1 journée',
    tools: ['Qonto', 'Pennylane', 'Notion'],
    benefits: [
      'Catalogue produits et devis multi-lignes signés',
      'Relances et lettrage bancaire automatisés',
      'Prévisionnel de trésorerie à 90 jours',
    ],
    color: 'green',
  },
  {
    id: 'C',
    name: 'Stack C — Commerciale intégrée',
    slug: '/stack-c/',
    price: '1 590 € HT + 1 200 € HT',
    detail: 'accompagnement + formation 2 jours',
    tools: ['Axonaut'],
    benefits: [
      'Pipeline commercial et CRM complet',
      'Automatisations et reporting avancé',
      'Équipe commerciale coordonnée',
    ],
    color: 'red',
  },
  {
    id: 'D',
    name: 'Stack D — BTP Artisan chantier',
    slug: '/stack-d/',
    price: '890 € HT',
    detail: 'formation 2h comprise',
    tools: ['Qonto', 'Obat / Trustup Pro'],
    benefits: [
      'Devis chantier structuré par lots',
      'Signature terrain et factures de situation',
      'Rentabilité chantier suivie en temps réel',
    ],
    color: 'amber',
  },
];

const colorMap: Record<string, { bg: string; border: string; text: string; badge: string }> = {
  blue:  { bg: 'bg-sky-900/20', border: 'border-sky-500/20', text: 'text-sky-400', badge: 'bg-sky-500/20 text-sky-300' },
  green: { bg: 'bg-emerald-900/20', border: 'border-emerald-500/20', text: 'text-emerald-400', badge: 'bg-emerald-500/20 text-emerald-300' },
  red:   { bg: 'bg-red-900/20', border: 'border-red-500/20', text: 'text-red-400', badge: 'bg-red-500/20 text-red-300' },
  amber: { bg: 'bg-amber-900/20', border: 'border-amber-500/20', text: 'text-amber-400', badge: 'bg-amber-500/20 text-amber-300' },
};
---

<Layout title={title} description={description}>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-alliance-dark-2 pt-24 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-alliance-blue/10 via-transparent to-transparent"></div>
    <div class="relative max-w-7xl mx-auto">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-alliance-orange/30 bg-alliance-orange/10 text-alliance-orange text-xs font-semibold uppercase tracking-wider mb-6" data-reveal>
          Comptabilité TPE · Clé en main
        </div>

        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight" data-reveal>
          <span class="hero-line">Votre comptabilité TPE,</span><br />
          <span class="gradient-text hero-line">sans complexité</span>
        </h1>

        <p class="text-lg sm:text-xl text-white/70 max-w-2xl mb-10 leading-relaxed" data-reveal>
          Vous ne cherchez pas un logiciel. Vous cherchez à être opérationnel, autonome et en règle.
          Nous installons vos outils, structurons votre gestion commerciale et vous formons sur votre propre environnement.
        </p>

        <div class="flex flex-col sm:flex-row items-start gap-4" data-reveal>
          <a href="#audit" class="btn-primary text-base px-8 py-4">Faire l'audit en 2 minutes</a>
          <a href="#offres" class="btn-secondary text-base px-8 py-4">Découvrir les offres</a>
        </div>
      </div>
    </div>
  </section>

  <!-- AUDIT FORM -->
  <section id="audit" class="py-16 md:py-24 bg-alliance-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12" data-reveal>
        <p class="text-alliance-blue text-sm font-bold uppercase tracking-widest mb-2">Audit gratuit</p>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">Identifiez votre besoin en 2 minutes</h2>
        <p class="text-white/60 text-lg">
          Répondez à quelques questions pour identifier le pack d'accompagnement le plus adapté à votre activité. Un conseiller vous recontacte sous 48 heures ouvrables.
        </p>
      </div>
      <div class="relief-panel fiber-pulse fiber-pulse--slow p-6 md:p-8" data-reveal>
        <MatriceAudit client:only="react" />
      </div>
    </div>
  </section>

  <!-- OFFERS -->
  <section id="offres" class="py-16 md:py-24 bg-alliance-dark-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-14" data-reveal>
        <p class="text-alliance-orange text-sm font-bold uppercase tracking-widest mb-2">Nos packs</p>
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">Accompagnement clé en main</h2>
        <p class="text-white/60 text-lg">
          Chaque stack combine installation, paramétrage et formation. Vous repartez avec vos outils opérationnels, votre documentation personnalisée et l'autonomie pour faire tourner votre quotidien.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        {stacks.map((stack, i) => {
          const c = colorMap[stack.color];
          return (
            <article class={`relief-panel relief-1 p-6 flex flex-col`} data-reveal data-reveal-delay={String(i * 0.08)}>
              <div class="flex items-center gap-3 mb-4">
                <span class={`w-10 h-10 rounded-lg flex items-center justify-center font-bold text-lg ${c.badge}`}>{stack.id}</span>
                <h3 class="font-display text-lg font-semibold text-white leading-tight">{stack.name}</h3>
              </div>
              <p class="text-2xl font-bold text-white mb-1">{stack.price}</p>
              <p class="text-sm text-white/50 mb-4">{stack.detail}</p>
              <div class="flex flex-wrap gap-2 mb-5">
                {stack.tools.map((tool) => (
                  <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${c.badge}`}>{tool}</span>
                ))}
              </div>
              <ul class="space-y-2 mb-6 flex-grow">
                {stack.benefits.map((benefit) => (
                  <li class="flex items-start gap-2 text-white/80">
                    <span class={`${c.text} mt-1`} aria-hidden="true">✓</span>
                    <span>{benefit}</span>
                  </li>
                ))}
              </ul>
              <a href={stack.slug} class="btn-primary w-full text-center">Voir le détail</a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- FORMATIONS -->
  <section class="py-16 md:py-24 bg-alliance-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center" data-reveal>
        <div>
          <p class="text-alliance-blue text-sm font-bold uppercase tracking-widest mb-2">Formations incluses</p>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-6">Vous repartez autonome</h2>
          <p class="text-white/70 text-lg mb-4">
            L'accompagnement Alliance Digitale ne se limite pas à installer un logiciel. Chaque pack inclut une formation action, réalisée dans votre environnement réel, avec vos vraies données.
          </p>
          <p class="text-white/70 text-lg mb-4">
            Le formateur paramètre une fois avec vous, puis vous l'exécutez deux fois seul. À l'issue de la session, vous disposez d'un livret personnalisé, de fiches réflexe et d'une hotline post-formation pour sécuriser votre autonomie.
          </p>
          <ul class="space-y-3 mt-6">
            <li class="flex items-start gap-3 text-white/80">
              <span class="text-alliance-orange font-bold">1.</span>
              <span>Formation individuelle ou en petit groupe (1 à 4 personnes)</span>
            </li>
            <li class="flex items-start gap-3 text-white/80">
              <span class="text-alliance-orange font-bold">2.</span>
              <span>Présentiel chez vous ou distanciel synchrone, selon votre convenance</span>
            </li>
            <li class="flex items-start gap-3 text-white/80">
              <span class="text-alliance-orange font-bold">3.</span>
              <span>Documentation personnalisée avec les captures de votre propre environnement</span>
            </li>
            <li class="flex items-start gap-3 text-white/80">
              <span class="text-alliance-orange font-bold">4.</span>
              <span>Attestation de formation et évaluation finale en autonomie</span>
            </li>
          </ul>
        </div>
        <div class="relief-panel p-8 fiber-pulse fiber-pulse--slow">
          <blockquote class="font-script text-3xl md:text-4xl leading-snug mb-6 text-white">
            "Une TPE qui reste dépendante d'un prestataire pour créer un devis n'a pas été formée : elle a été rendue captive."
          </blockquote>
          <p class="text-white/70">Notre objectif : vous rendre autonome, en règle et opérationnel dès le lendemain.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-alliance-dark-2">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-reveal>
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white mb-4">Prêt à sécuriser votre gestion commerciale ?</h2>
      <p class="text-lg text-white/70 mb-8">
        Commencez par l'audit gratuit. En 2 minutes, nous identifions ensemble le pack le plus pertinent pour votre activité.
      </p>
      <a href="#audit" class="btn-primary text-lg px-8 py-4">Faire l'audit maintenant</a>
    </div>
  </section>
</Layout>

<script>
  import '@fontsource/inter/300.css';
  import '@fontsource/inter/400.css';
  import '@fontsource/inter/500.css';
  import '@fontsource/inter/600.css';
  import '@fontsource/inter/700.css';
  import '@fontsource/inter/800.css';
  import '@fontsource/playfair-display/600.css';
  import '@fontsource/playfair-display/700.css';
  import '@fontsource/space-grotesk/400.css';
  import '@fontsource/space-grotesk/500.css';
  import '@fontsource/space-grotesk/600.css';
  import '@fontsource/space-grotesk/700.css';
</script>